# Kopieer dit bestand naar .env (dat staat in .gitignore en hoort niet in git).
# Hier staan de instellingen die per computer/server kunnen verschillen.

# Nu: SQLite. De database is gewoon één bestand.
DB_PATH=database/database.sqlite

# Later naar MySQL? Dan zet je hier de echte gegevens neer (en pas je
# Database.php aan naar een mysql-DSN):
# DB_HOST=localhost
# DB_NAME=evenementen
# DB_USER=root
# DB_PASS=
